-- // 15 (Draggable â€” respects lock) //
do
	local dg, ds, sp = false, nil, nil

	local function clamp(pos)
		local ss = workspace.CurrentCamera.ViewportSize
		local gs = prime.AbsoluteSize
		return UDim2.new(0,
			math.clamp(pos.X.Offset, 0, math.max(0, ss.X - gs.X)),
			0,
			math.clamp(pos.Y.Offset, 0, math.max(0, ss.Y - gs.Y))
		)
	end

	prime.InputBegan:Connect(function(input)
		if primeDragLocked then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			dg = true
			ds = input.Position
			sp = prime.Position
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if not dg then return end
		if primeDragLocked then dg = false return end
		if input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch then
			local d = input.Position - ds
			prime.Position = clamp(UDim2.new(
				sp.X.Scale, sp.X.Offset + d.X,
				sp.Y.Scale, sp.Y.Offset + d.Y
			))
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			dg = false
		end
	end)
end

